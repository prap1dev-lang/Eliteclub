# ════════════════════════════════════════════════════════════
#  ELITE CLUB — Environment Variables
#  Copy this file to ".env.local" and fill in your real values.
# ════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# SERVER ONLY — never exposed to the browser. Used for registration inserts + admin.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY

# ── Cloudinary (unsigned uploads from the browser) ────────────
# Cloudinary Dashboard → cloud name shown at top.
# Settings → Upload → Upload presets → add an UNSIGNED preset.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR_UNSIGNED_PRESET

# ── Admin Panel ───────────────────────────────────────────────
# Password to log into /admin. CHANGE THIS to something strong.
ADMIN_PASSWORD=change-me-to-a-strong-password
# A long random string used to sign the admin session cookie.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-string
